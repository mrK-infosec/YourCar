# Server configuration settings
PORT=5000
NODE_ENV=development

# Database connection URL - use local MongoDB or Atlas URL
MONGODB_URI=mongodb://127:0:0:1:27017/timgad-motors

# JWT Secret Key - used for signing and validating admin tokens (change this to a secure random string in production!)
JWT_SECRET=your_super_secret_jwt_key_here

# Cookie security settings (seconds for JWT expiration, e.g. 1 day)
JWT_EXPIRES_IN=24h

# Admin Credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash_here
